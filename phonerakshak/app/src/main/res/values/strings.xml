    <!-- Boot recovery consent -->
    <string name="boot_recovery_title">Boot Recovery (recommended)</string>
    <string name="boot_recovery_explainer">If your phone is stolen and turned off and on again, PhoneRakshak can automatically send a one-time status update to your account (or, if no server is set, to your emergency contact via SMS).\n\nThe update contains:\n• Battery level and charging state\n• Network type (Wi-Fi or mobile)\n• The last known location already saved on this device\n\nNo new tracking is started without your other settings. You can turn this off any time from this screen.</string>
    <string name="boot_recovery_toggle">Send a status update to my account when the phone reboots</string>

