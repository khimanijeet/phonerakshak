    <!-- Device admin -->
    <string name="admin_label">PhoneRakshak Device Admin</string>
    <string name="admin_description">Allows the PhoneRakshak app to lock the device when an SMS LOCK command is received.</string>
    <string name="admin_explanation">Enabling this lets the app lock your screen when you send the LOCK SMS from another phone.</string>

    <!-- SMS help -->
    <string name="sms_help">SMS commands (replace 123 with your PIN):\n• LOCK&lt;PIN&gt; — lock the device\n• LOC&lt;PIN&gt; — reply with GPS link\n• ALARM&lt;PIN&gt; — sound alarm\n• STOPALARM&lt;PIN&gt; — stop alarm\n• SOS&lt;PIN&gt; — trigger Emergency Mode\n\nIf the SIM is changed, an alert SMS with the current location is sent to your emergency contact.</string>

