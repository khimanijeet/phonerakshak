<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/setup_title"
            android:textColor="@color/text"
            android:textSize="22sp"
            android:textStyle="bold"
            android:paddingBottom="20dp" />

        <LinearLayout style="@style/PR.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <EditText
                android:id="@+id/inputPhone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_input"
                android:padding="14dp"
                android:textColor="@color/text"
                android:textColorHint="@color/muted"
                android:hint="@string/hint_phone"
                android:inputType="phone"
                android:autofillHints="phone" />

            <EditText
                android:id="@+id/inputEmergency"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_input"
                android:padding="14dp"
                android:textColor="@color/text"
                android:textColorHint="@color/muted"
                android:hint="@string/hint_emergency"
                android:inputType="phone"
                android:layout_marginTop="10dp" />

            <EditText
                android:id="@+id/inputPin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_input"
                android:padding="14dp"
                android:textColor="@color/text"
                android:textColorHint="@color/muted"
                android:hint="@string/hint_pin"
                android:inputType="numberPassword"
                android:maxLength="8"
                android:layout_marginTop="10dp" />

            <EditText
                android:id="@+id/inputBackend"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_input"
                android:padding="14dp"
                android:textColor="@color/text"
                android:textColorHint="@color/muted"
                android:hint="@string/hint_backend"
                android:inputType="textUri"
                android:layout_marginTop="10dp" />
        </LinearLayout>

        <LinearLayout style="@style/PR.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/boot_recovery_title"
                android:textColor="@color/text"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textSize="13sp"
                android:textColor="@color/muted"
                android:text="@string/boot_recovery_explainer" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switchBootRecovery"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:textColor="@color/text"
                android:text="@string/boot_recovery_toggle" />
        </LinearLayout>

        <LinearLayout style="@style/PR.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <Button
                android:id="@+id/btnAdmin"
                style="@style/PR.Button.Secondary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/btn_admin" />

            <TextView
                android:id="@+id/txtAdminStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textSize="13sp"
                android:textColor="@color/muted"
                android:text="@string/status_admin_off" />

            <Button
                android:id="@+id/btnSave"
                style="@style/PR.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/btn_save"
                android:layout_marginTop="14dp" />

            <Button
                android:id="@+id/btnDashboard"
                style="@style/PR.Button.Secondary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/btn_open_dashboard"
                android:layout_marginTop="10dp" />

            <Button
                android:id="@+id/btnTestLock"
                style="@style/PR.Button.Secondary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/btn_test_lock"
                android:layout_marginTop="10dp" />

            <Button
                android:id="@+id/btnIntruders"
                style="@style/PR.Button.Secondary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/btn_view_intruders"
                android:layout_marginTop="10dp" />

            <TextView
                android:id="@+id/txtStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:textSize="14sp"
                android:textColor="@color/muted"
                android:text="@string/status_stopped" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textSize="12sp"
            android:textColor="@color/muted"
            android:textStyle="italic"
            android:text="@string/sms_help" />

    </LinearLayout>
</ScrollView>
