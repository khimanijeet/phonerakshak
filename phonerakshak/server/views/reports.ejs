<% const leaflet = false; const chartjs = false; const active = 'reports'; %>
<%- include('partials/header', { title: 'Reports — Phonerakshak Admin', leaflet }) %>
<div class="app-shell">
  <%- include('partials/sidebar', { active }) %>
  <main class="app-main">
    <%- include('partials/topbar', { pageTitle: 'Reports' }) %>
    <div class="content">
      <section class="card">
        <header class="card-header"><h2>All Reports & Alerts</h2><span class="muted"><%= reports.length %> total</span></header>
        <div class="table-wrap">
          <table class="data-table">
            <thead><tr><th>Type</th><th>Device</th><th>Message</th><th>Status</th><th>Time</th></tr></thead>
            <tbody>
              <% if (reports.length === 0) { %>
                <tr><td colspan="5" class="empty">No reports yet</td></tr>
              <% } %>
              <% reports.forEach(function(r){ %>
                <tr>
                  <td><span class="pill pill-grey"><%= (r.type || '').replace(/_/g,' ') %></span></td>
                  <td class="mono"><%= r.deviceId %></td>
                  <td><%= r.message || '—' %></td>
                  <td><span class="status status-<%= r.status %>"><%= r.status %></span></td>
                  <td><%= new Date(r.timestamp).toLocaleString() %></td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      </section>
    </div>
  </main>
</div>
<%- include('partials/footer') %>
