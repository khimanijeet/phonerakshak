<% const leaflet = false; const chartjs = false; %>
<%- include('partials/header', { title: 'Reset password — Phonerakshak Admin', leaflet }) %>
<div class="login-shell">
  <div class="login-card">
    <div class="login-brand">
      <div class="brand-icon big">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
      </div>
      <div>
        <div class="brand-title big">Reset Password</div>
        <div class="brand-sub">Phonerakshak Admin</div>
      </div>
    </div>

    <% if (error) { %>
      <div class="error-banner"><%= error %></div>
    <% } %>
    <% if (notice) { %>
      <div class="notice-banner"><%= notice %></div>
    <% } %>

    <% if (!resetEnabled) { %>
      <p class="login-hint">
        Password reset is currently disabled. To enable it, add a Replit Secret named
        <code>ADMIN_RESET_TOKEN</code> with a long, random value, then restart the app.
        After resetting, rotate or remove the token.
      </p>
      <p class="login-hint"><a href="/login" class="forgot-link">← Back to sign in</a></p>
    <% } else { %>
      <form method="POST" action="/forgot-password" class="login-form">
        <label>Username</label>
        <input name="username" required autofocus value="<%= username %>" autocomplete="username" />

        <label>Reset token</label>
        <input name="token" type="password" required placeholder="From ADMIN_RESET_TOKEN secret" autocomplete="off" />

        <label>New password</label>
        <input name="newPassword" type="password" required minlength="8" autocomplete="new-password" />

        <label>Confirm new password</label>
        <input name="confirmPassword" type="password" required minlength="8" autocomplete="new-password" />

        <button class="btn-primary" type="submit">Reset password</button>
      </form>
      <p class="login-hint">
        The reset token is the value of the <code>ADMIN_RESET_TOKEN</code> Replit Secret.
        Rotate or delete it after a successful reset.
      </p>
      <p class="login-hint"><a href="/login" class="forgot-link">← Back to sign in</a></p>
    <% } %>
  </div>
</div>
<%- include('partials/footer') %>
