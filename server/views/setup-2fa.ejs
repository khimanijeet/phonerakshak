<% const leaflet = false; const chartjs = false; const active = 'settings'; %>
<%- include('partials/header', { title: 'Security Settings — Phonerakshak Admin', leaflet }) %>
<div class="app-shell">
  <%- include('partials/sidebar', { active }) %>
  <main class="app-main">
    <%- include('partials/topbar', { pageTitle: 'Security Settings' }) %>
    <div class="content" style="max-width: 600px; margin: 0 auto; padding-top: 40px;">
      
      <section class="card">
        <header class="card-header" style="border-bottom: 1px solid var(--border); padding-bottom: 16px; margin-bottom: 20px;">
          <h2 style="display: flex; align-items: center; gap: 8px;">🔐 Multi-Admin 2FA</h2>
        </header>

        <% if (isEnabled) { %>
          <div style="text-align: center; padding: 40px 20px;">
            <div style="font-size: 64px; margin-bottom: 16px;">🛡️</div>
            <h3 style="color: #10b981; margin-bottom: 12px;">Two-Factor Authentication is Enabled</h3>
            <p class="muted" style="margin-bottom: 30px;">Your admin dashboard is secured. A 6-digit authenticator code is required to log in.</p>
            
            <form method="POST" action="/admin/disable-2fa" style="background: var(--card-2); padding: 20px; border-radius: 12px; border: 1px solid var(--border);">
              <h4 style="margin-bottom: 16px; text-align: left;">Disable 2FA</h4>
              <p class="muted small" style="text-align: left; margin-bottom: 16px;">To disable 2FA, please enter your current admin password.</p>
              <input type="password" name="password" class="input" placeholder="Admin Password" required style="width: 100%; margin-bottom: 16px;">
              <button class="btn-primary" type="submit" style="width: 100%; background: #ef4444;">Disable 2FA</button>
            </form>
          </div>
        <% } else { %>
          <div>
            <p style="margin-bottom: 20px;">Protect your admin dashboard with two-factor authentication. Once enabled, you will need to enter a 6-digit code from your authenticator app (like Google Authenticator or Authy) whenever you log in.</p>
            
            <div style="background: var(--card-2); padding: 24px; border-radius: 12px; border: 1px solid var(--border); text-align: center; margin-bottom: 24px;">
              <h4 style="margin-bottom: 16px;">1. Scan QR Code</h4>
              <p class="muted small" style="margin-bottom: 16px;">Open your authenticator app and scan the barcode below:</p>
              <div style="background: white; padding: 10px; display: inline-block; border-radius: 8px; margin-bottom: 16px;">
                <img src="<%= qrDataUrl %>" alt="QR Code" style="display: block;">
              </div>
              <p class="muted small">Or enter this secret manually: <br><strong style="color: white; font-family: monospace; letter-spacing: 2px;"><%= secret %></strong></p>
            </div>

            <div style="background: var(--card-2); padding: 24px; border-radius: 12px; border: 1px solid var(--border);">
              <h4 style="margin-bottom: 16px;">2. Verify Setup</h4>
              <p class="muted small" style="margin-bottom: 16px;">Enter the 6-digit code generated by your app to verify and enable 2FA.</p>
              
              <% if (typeof error !== 'undefined' && error) { %>
                <div style="background: rgba(239, 68, 68, 0.1); color: #f87171; padding: 12px; border-radius: 8px; margin-bottom: 16px; text-align: center; font-size: 14px;">
                  <%= error %>
                </div>
              <% } %>

              <form method="POST" action="/admin/setup-2fa">
                <input type="text" name="token" class="input" placeholder="000000" pattern="[0-9]{6}" required style="width: 100%; text-align: center; font-size: 24px; letter-spacing: 4px; font-family: monospace; margin-bottom: 16px;" maxlength="6" autocomplete="off">
                <button class="btn-primary" type="submit" style="width: 100%;">Verify & Enable 2FA</button>
              </form>
            </div>
          </div>
        <% } %>

      </section>
    </div>
  </main>
</div>
<%- include('partials/footer', { leaflet: false }) %>
